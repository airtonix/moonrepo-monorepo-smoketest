{
  "separate-pull-requests": true,
  "versioning": "always-bump-minor",
  "bump-patch-for-minor-pre-major": true,
  "release-type": "node",
  "packages": {
    "apps/api_service": {
      "group": "apps"
    },
    "apps/dashboard": {
      "group": "apps"
    },
    "apps/docs_site": {
      "group": "apps"
    },
    "pkgs/cli/something": {
      "group": "pkgs",
      "release-type": "go"
    },
    "pkgs/libs/counter": {
      "group": "pkgs"
    },
    "pkgs/libs/hello": {
      "group": "pkgs"
    }
  },
  "plugins": [
    {
      "type": "node-workspace"
    },
    {
      "type": "group-priority",
      "groups": [
        "apps"
      ]
    }
  ],
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
