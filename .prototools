# Proto toolchain config (project-local)
# Docs: https://moonrepo.dev/docs/proto/config

# Pin tool versions used in this repo.
hk = "1.37.0"
actionlint = "1.7.11"
bun = "1.3.2"
go = "1.25.1"
usage = "2.18.2"

[settings]
detect-strategy = "only-prototools"
auto-install = true
builtin-plugins = ["bun", "go"]

[plugins.tools]
hk = "file://./proto/plugins/hk.toml"
actionlint = "file://./proto/plugins/actionlint.toml"
usage = "file://./proto/plugins/usage.toml"
