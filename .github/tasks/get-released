#!/usr/bin/env bash

# Takes a release-please output and
# extracts information in usable ways.

set -euo pipefail

cmd_help() {
	cat <<'EOF'
Usage:
  get-released help
  get-released manifest <release_please_json_payload> [mode] [tag]
  get-released appnames <release_please_json_payload>

Commands:
  help      Show this help
  manifest  Output publish matrix [{ target, tag, mode, version }]
  appnames  Output string[] of released app names
EOF
}

require_payload() {
	local payload="${1:-}"

	if [[ -z "$payload" ]]; then
		echo "Missing JSON payload argument" >&2
		exit 1
	fi

	if ! jq -e . >/dev/null 2>&1 <<<"$payload"; then
		echo "Invalid JSON payload passed as argv[0]" >&2
		exit 1
	fi
}

moon_project_index() {
	if command -v moon >/dev/null 2>&1; then
		if moon projects --json 2>/dev/null | jq -ce 'map({ key: .source, value: .id }) | from_entries' 2>/dev/null; then
			return 0
		fi
	fi

	echo '{}'
}

cmd_to_manifest() {
	local payload="${1:-}"
	local mode="${2:-normal}"
	local tag="${3:-latest}"
	local project_index
	require_payload "$payload"
	project_index="$(moon_project_index)"

	jq -cn --argjson data "$payload" --argjson project_index "$project_index" --arg mode "$mode" --arg tag "$tag" '
    def released_paths:
      if ($data.paths_released | type) == "string" then
        ($data.paths_released | fromjson? // [])
      elif ($data.paths_released | type) == "array" then
        $data.paths_released
      else
        []
      end;

    released_paths
      | map({
          target: ($project_index[.] // (split("/")[-1])),
          tag: $tag,
          mode: $mode,
          version: ($data[(. + "--version")] // "")
        })
  '
}

cmd_to_appnames() {
	local payload="${1:-}"
	local project_index
	require_payload "$payload"
	project_index="$(moon_project_index)"

	jq -cn --argjson data "$payload" --argjson project_index "$project_index" '
    def released_paths:
      if ($data.paths_released | type) == "string" then
        ($data.paths_released | fromjson? // [])
      elif ($data.paths_released | type) == "array" then
        $data.paths_released
      else
        []
      end;

    released_paths | map($project_index[.] // split("/")[-1])
  '
}

main() {
	local subcmd="${1:-help}"

	case "$subcmd" in
	manifest)
		cmd_to_manifest "${2:-}" "${3:-}" "${4:-}"
		;;
	appnames)
		cmd_to_appnames "${2:-}"
		;;
	help)
		cmd_help
		;;
	*)
		cmd_help
		;;
	esac
}

main "$@"
