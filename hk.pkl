amends "package://github.com/jdx/hk/releases/download/v1.26.0/hk@1.26.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.26.0/hk@1.26.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    // eslint for TypeScript files
    ["eslint"] {
        glob = "**/*.ts"
        check = "eslint {{files}}"
        fix = "eslint --fix {{files}}"
    }

    // uses builtin prettier linter config
    ["prettier"] = Builtins.prettier

    // enforce moon tasks by disallowing package.json scripts
    // Convention: pkgs/* must use moon tasks; apps/* may have scripts (moon proxies to them)
    ["no-package-scripts"] {
        glob = "pkgs/**/package.json"
        check = "python -c \"import json,sys; bad=[]\nfor f in sys.argv[1:]:\n d=json.load(open(f))\n if 'scripts' in d: bad.append(f)\nprint('ERROR: scripts field is forbidden in package.json (use moon tasks):\\n' + '\\n'.join(bad)) if bad else None\nsys.exit(1 if bad else 0)\" {{files}}"
        fix = "python -c \"import json,sys\nfor f in sys.argv[1:]:\n d=json.load(open(f))\n if 'scripts' in d:\n  d.pop('scripts', None)\n  open(f,'w').write(json.dumps(d, indent=2) + '\\n')\" {{files}}"
    }

    // lint changed GitHub workflow files
    ["actionlint"] {
        glob = ".github/workflows/*.yml"
        check = "bash -lc 'ACTIONLINT=\"$(command -v actionlint || proto bin actionlint 2>/dev/null)\"; [ -n \"$ACTIONLINT\" ] || { echo \"ERROR: actionlint is required. Run: proto install actionlint\"; exit 1; }; \"$ACTIONLINT\" {{files}}'"
    }

    // define a custom linter
    ["pkl"] {
        glob = "*.pkl"
        check = "pkl eval {{files}} >/dev/null"
    }
}

hooks {
    ["pre-commit"] {
        fix = true    // automatically modify files with available linter fixes
        stash = "git" // stashes unstaged changes while running fix steps
        steps {
            ...linters // add all linters defined above
        }
    }
    // instead of pre-commit, you can instead define pre-push hooks
    ["pre-push"] {
        steps = linters
    }
    // "fix" and "check" are special steps for `hk fix` and `hk check` commands
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
